<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BudgetMate" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/bm_primary</item>
        <item name="colorPrimaryVariant">@color/bm_primary_dark</item>
        <item name="colorSecondary">@color/bm_secondary</item>
        <item name="android:colorBackground">@color/bm_bg</item>
        <item name="colorSurface">@color/bm_surface</item>
        <item name="android:statusBarColor">@color/bm_primary_dark</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/budgetmate_logo</item>
        <item name="android:windowSplashScreenBackground">@color/bm_bg</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.BudgetMate.RoundAlertDialog</item>
        <item name="materialButtonStyle">@style/Widget.BudgetMate.Button</item>
        <item name="editTextStyle">@style/Widget.BudgetMate.EditText</item>
        <item name="android:editTextStyle">@style/Widget.BudgetMate.EditText</item>
    </style>

    <style name="Widget.BudgetMate.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">18dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/bm_primary</item>
        <item name="android:textColor">@color/bm_surface</item>
    </style>

    <style name="Widget.BudgetMate.EditText" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/bg_edit_text_rounded</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textColor">@color/bm_text_primary</item>
        <item name="android:textColorHint">@color/bm_text_secondary</item>
    </style>

    <style name="ThemeOverlay.BudgetMate.RoundAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.BudgetMate.AlertDialog</item>
    </style>

    <style name="ShapeAppearanceOverlay.BudgetMate.AlertDialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="ShapeAppearanceOverlay.BudgetMate.CircleImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>
